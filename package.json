  "main": "index.js",
  "scripts": {
    "prisma:generate": "prisma generate --schema=src/infra/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/infra/database/prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=src/infra/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/infra/database/prisma/schema.prisma",
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
